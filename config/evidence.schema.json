{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogni-os.local/schema/evidence.v1.json",
  "title": "Cogni-OS Evidence and Claim Records v1",
  "oneOf": [
    { "$ref": "#/$defs/evidenceRecordV1" },
    { "$ref": "#/$defs/claimRecordV1" },
    { "$ref": "#/$defs/journalEntryV1" }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]{0,127}$"
    },
    "scopeV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_sha256",
        "code_sha256",
        "config_sha256",
        "device_sha256"
      ],
      "properties": {
        "model_sha256": { "$ref": "#/$defs/sha256" },
        "code_sha256": { "$ref": "#/$defs/sha256" },
        "config_sha256": { "$ref": "#/$defs/sha256" },
        "device_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "evidenceRecordV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "schema_version",
        "evidence_id",
        "recorded_at",
        "kind",
        "producer",
        "run_id",
        "evidence_class",
        "claim_ids",
        "artifact_sha256",
        "payload_sha256",
        "scope",
        "metadata"
      ],
      "properties": {
        "record_type": { "const": "evidence" },
        "schema_version": { "const": 1 },
        "evidence_id": {
          "type": "string",
          "pattern": "^ev1-[0-9a-f]{64}$"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64
        },
        "kind": { "$ref": "#/$defs/identifier" },
        "producer": { "$ref": "#/$defs/identifier" },
        "run_id": { "$ref": "#/$defs/identifier" },
        "evidence_class": {
          "enum": ["measured", "verified", "target", "plan"]
        },
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10000,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "artifact_sha256": { "$ref": "#/$defs/sha256" },
        "payload_sha256": { "$ref": "#/$defs/sha256" },
        "scope": { "$ref": "#/$defs/scopeV1" },
        "metadata": {
          "type": "object",
          "maxProperties": 64,
          "propertyNames": { "$ref": "#/$defs/identifier" },
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    },
    "claimRecordV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "schema_version",
        "claim_id",
        "statement",
        "evidence_class",
        "evidence_ids"
      ],
      "properties": {
        "record_type": { "const": "claim" },
        "schema_version": { "const": 1 },
        "claim_id": { "$ref": "#/$defs/identifier" },
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "evidence_class": {
          "enum": ["measured", "verified", "target", "plan"]
        },
        "evidence_ids": {
          "type": "array",
          "maxItems": 100000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev1-[0-9a-f]{64}$"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "evidence_class": { "const": "verified" } },
            "required": ["evidence_class"]
          },
          "then": {
            "properties": { "evidence_ids": { "minItems": 1 } }
          }
        }
      ]
    },
    "journalEntryV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "previous_sha256",
        "record",
        "entry_sha256"
      ],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "previous_sha256": { "$ref": "#/$defs/sha256" },
        "record": { "$ref": "#/$defs/evidenceRecordV1" },
        "entry_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
